{
  "name": "parke-dev-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/blog dev",
    "build": "bun run --cwd apps/blog build",
    "preview": "bun run --cwd apps/blog preview",
    "astro": "bun run --cwd apps/blog astro",
    "dev:blog": "bun run --cwd apps/blog dev",
    "build:blog": "bun run --cwd apps/blog build",
    "preview:blog": "bun run --cwd apps/blog preview",
    "dev:portfolio": "bun run --cwd apps/portfolio dev",
    "build:portfolio": "bun run --cwd apps/portfolio build",
    "preview:portfolio": "bun run --cwd apps/portfolio preview",
    "start": "npx serve -l 3000 apps/blog/dist"
  },
  "dependencies": {
    "serve": "^14.2.4"
  }
}
